{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "KnowledgeNode",
  "description": "统一知识节点定义，考试局无关",
  "type": "object",
  "required": ["kn_id", "version", "title_en", "title_zh", "domain"],
  "properties": {
    "kn_id": { "type": "string", "pattern": "^kn_[0-9]{4}$" },
    "version": { "type": "integer", "minimum": 1 },
    "title_en": { "type": "string" },
    "title_zh": { "type": "string" },
    "title_short": { "type": "string" },
    "domain": {
      "type": "string",
      "enum": ["number", "algebra", "geometry", "statistics", "probability"]
    },
    "subdomain": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "examBoards": {
      "type": "object",
      "properties": {
        "cie_0580": {
          "type": "object",
          "properties": {
            "section": { "type": "string" },
            "kpId": { "type": "string" },
            "tier": { "enum": ["core", "extended", "both"] },
            "weight": { "enum": ["highest", "high", "medium", "low", "rare", "none"] },
            "paperCodes": { "type": "array", "items": { "type": "string" } }
          }
        },
        "edexcel_4ma1": {
          "type": "object",
          "properties": {
            "section": { "type": "string" },
            "tier": { "enum": ["foundation", "higher", "both"] },
            "weight": { "enum": ["highest", "high", "medium", "low", "rare", "none"] },
            "paperCodes": { "type": "array", "items": { "type": "string" } }
          }
        },
        "hhk": {
          "type": "object",
          "properties": {
            "units": { "type": "array", "items": { "type": "string" } },
            "year": { "type": "integer", "minimum": 7, "maximum": 12 },
            "unitTitle": { "type": "string" }
          }
        }
      }
    },
    "country_curriculum": {
      "type": "object",
      "description": "TASK-027 · 国家课标维度(扩展国内 K-12)· 与 examBoards 正交",
      "properties": {
        "cn_renjiao": {
          "type": "object",
          "description": "中国人教版课标(7-9 年级)",
          "properties": {
            "grade": { "type": "integer", "minimum": 1, "maximum": 12 },
            "chapter": { "type": "string" },
            "section": { "type": "string" },
            "topic_zh": { "type": "string" }
          }
        },
        "cn_beishi": {
          "type": "object",
          "description": "北师大版课标(预留)",
          "properties": {
            "grade": { "type": "integer" },
            "chapter": { "type": "string" }
          }
        },
        "cn_huadong": {
          "type": "object",
          "description": "华东师大版课标(预留)",
          "properties": {
            "grade": { "type": "integer" },
            "chapter": { "type": "string" }
          }
        }
      }
    },
    "sow_version": {
      "type": "object",
      "description": "TASK-027 · School-specific SoW 版本追踪 · 学校升级课纲时不破坏历史 mapping",
      "properties": {
        "hhk_y10_v1": { "type": "string", "description": "Harrow Haikou Y10 SoW 2024-25 版本号" },
        "hhk_y11_v1": { "type": "string" }
      },
      "additionalProperties": {
        "type": "string",
        "description": "Free-form key 'school_grade_versionN' · value = adoption-date or notes"
      }
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kn_id", "type"],
        "properties": {
          "kn_id": { "type": "string" },
          "type": { "enum": ["hard", "soft"] },
          "reason": { "type": "string" }
        }
      }
    },
    "leadsTo": { "type": "array", "items": { "type": "string" } },
    "difficultyRange": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "integer", "minimum": 1, "maximum": 4 }
    },
    "estimatedMinutes": {
      "type": "object",
      "properties": {
        "concept": { "type": "integer" },
        "practice": { "type": "integer" }
      }
    },
    "content": {
      "type": "object",
      "properties": {
        "variants": {
          "type": "object",
          "properties": {
            "cie": { "type": "array", "items": { "type": "string" } },
            "edexcel": { "type": "array", "items": { "type": "string" } },
            "generic": { "type": "array", "items": { "type": "string" } }
          }
        },
        "missions": { "type": "array", "items": { "type": "integer" } },
        "glGeneratorId": { "type": ["string", "null"] },
        "examRefs": {
          "type": "object",
          "properties": {
            "cie": { "type": "integer" },
            "edexcel": { "type": "integer" }
          }
        }
      }
    },
    "noFigure": { "type": "boolean" },
    "isFoundational": { "type": "boolean" },
    "deprecated": { "type": "boolean", "default": false },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
